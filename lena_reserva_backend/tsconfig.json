{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "sourceMap": true,

    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
 
  ]
}

{
 "scripts":{

 "dev":"tsx watch src/server.ts",

 "build":"tsc",

 "start":"node dist/server.js",

 "prisma:migrate":"prisma migrate dev",

 "prisma:generate":"prisma generate"

 }
}